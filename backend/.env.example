APP_NAME=StoreHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Database (local / Docker — MySQL) ────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=storehub
DB_USERNAME=storehub_user
DB_PASSWORD=secret

# ─── Database (Render — PostgreSQL) ───────────────────────────────────────────
# Uncomment and fill these when deploying to Render. Set DB_CONNECTION=pgsql.
# DB_CONNECTION=pgsql
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

CACHE_STORE=file

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync

MAIL_MAILER=log
